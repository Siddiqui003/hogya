# Production environment variables for the client build.
#
# If you deploy frontend and backend as the SAME origin (SERVE_CLIENT=true
# on the server, or a reverse proxy that rewrites /api to the backend),
# you can leave these as relative paths and they'll just work:
#
#   VITE_API_URL=/api
#   VITE_SOCKET_URL=  (leave empty — Socket.IO will use the current origin)
#
# If frontend and backend are on DIFFERENT origins (e.g. Vercel + Render),
# point these at the full backend URL:

VITE_API_URL=https://your-backend.example.com/api
VITE_SOCKET_URL=https://your-backend.example.com
